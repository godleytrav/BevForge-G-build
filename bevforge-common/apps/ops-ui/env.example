# Application
VITE_APP_NAME=v8 App Template
VITE_PUBLIC_URL=http://localhost:5182
VITE_API_URL=http://localhost:3000/api

# Server
NODE_ENV=development
PORT=5182

# Features
VITE_ENABLE_SOURCE_MAPPING=true
VITE_ENABLE_SSR=true

# Development Tools
VITE_SHOW_DEV_TOOLS=false

# Database (when needed)
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Generated MySQL User Credentials (auto-managed by the system)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=user_<random>
# DB_PASS=<generated_password>
# DB_NAME=<schema_name>

# External APIs (when needed)
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
# Google Maps JavaScript API key for OPS CRM/Logistics map views
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Suite Handoff URLs (optional)
# Use these to force cross-suite navigation targets from OPS header/menu.
# VITE_OS_SUITE_URL=http://127.0.0.1:5181
# VITE_OPS_SUITE_URL=http://127.0.0.1:5182
# VITE_LAB_SUITE_URL=http://127.0.0.1:5175
# VITE_FLOW_SUITE_URL=http://127.0.0.1:5182
# VITE_CONNECT_SUITE_URL=http://127.0.0.1:5182

# Authentication (when needed)
# JWT_SECRET=your-secret-here
# SESSION_SECRET=your-secret-here
