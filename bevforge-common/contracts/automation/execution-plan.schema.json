{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/automation/execution-plan.schema.json",
  "title": "BevForge Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "sourceType", "steps"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string"
    },
    "sourceType": {
      "type": "string",
      "enum": ["canvas_automation", "recipe"]
    },
    "sourceId": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["command", "delay", "condition", "notify"]
        },
        "targetDeviceId": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "enum": ["on_off", "open_close", "route", "set_value", "trigger"]
        },
        "value": {
          "type": ["string", "number", "boolean"]
        },
        "delayMs": {
          "type": "integer",
          "minimum": 0
        },
        "condition": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "left": { "type": "string" },
            "operator": {
              "type": "string",
              "enum": ["gt", "gte", "lt", "lte", "eq", "neq", "in_range"]
            },
            "right": { "type": ["number", "string", "boolean"] },
            "rangeMin": { "type": "number" },
            "rangeMax": { "type": "number" }
          }
        },
        "message": {
          "type": "string"
        },
        "requireUserProceed": {
          "type": "boolean"
        },
        "fallbackStepIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
