{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/automation/automation-rule.schema.json",
  "title": "BevForge Automation Rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "triggers", "actions"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trigger"
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/condition"
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["manual", "button_press", "sensor_threshold", "schedule", "event"]
        },
        "sourceId": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": ["gt", "gte", "lt", "lte", "eq", "neq"]
        },
        "value": {
          "type": ["number", "string", "boolean"]
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "operator"],
      "properties": {
        "left": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": ["gt", "gte", "lt", "lte", "eq", "neq", "in_range"]
        },
        "right": {
          "type": ["number", "string", "boolean"]
        },
        "rangeMin": {
          "type": "number"
        },
        "rangeMax": {
          "type": "number"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["command", "delay", "notify", "set_state"]
        },
        "targetDeviceId": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "enum": ["on_off", "open_close", "route", "set_value", "trigger"]
        },
        "value": {
          "type": ["string", "number", "boolean"]
        },
        "delayMs": {
          "type": "integer",
          "minimum": 0
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
