{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/canvas/canvas-base.schema.json",
  "title": "BevForge Canvas Base",
  "description": "Shared base schema for OS and OPS canvas graphs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "nodes", "edges"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this contract."
    },
    "id": {
      "type": "string",
      "description": "Unique canvas id."
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "canvas-node.schema.json"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target"],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Optional edge type for routing and execution semantics."
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
