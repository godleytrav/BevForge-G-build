{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/calendar/calendar-event.schema.json",
  "title": "BevForge Calendar Event",
  "description": "Canonical event shape used by the universal calendar projection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "sourceSuite",
    "title",
    "type",
    "status",
    "startAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string"
    },
    "sourceSuite": {
      "type": "string",
      "enum": ["os", "ops", "lab", "flow", "connect"]
    },
    "sourceRecordId": {
      "type": "string"
    },
    "siteId": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "production",
        "inventory",
        "order",
        "delivery",
        "compliance",
        "schedule",
        "maintenance",
        "task",
        "note"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "completed", "canceled", "blocked"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "startAt": {
      "type": "string",
      "format": "date-time"
    },
    "endAt": {
      "type": "string",
      "format": "date-time"
    },
    "timezone": {
      "type": "string"
    },
    "allDay": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openPath": {
          "type": "string"
        },
        "openUrl": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
