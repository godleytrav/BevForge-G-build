{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/brewhouse/brewhouse.schema.json",
  "title": "BevForge Brewhouse",
  "description": "Logical brewhouse definition used by OS and OPS.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "devices"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "devices": {
      "type": "array",
      "items": {
        "$ref": "device-binding.schema.json"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
