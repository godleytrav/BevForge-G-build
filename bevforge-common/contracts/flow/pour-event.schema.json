{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/flow/pour-event.schema.json",
  "title": "BevForge FLOW Pour Event",
  "description": "Idempotent serving event emitted by FLOW and consumed by OS depletion ledger.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "siteId",
    "tapId",
    "volume",
    "uom",
    "occurredAt",
    "sourceMode"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "eventId": {
      "type": "string",
      "description": "Stable idempotency key generated by FLOW."
    },
    "siteId": {
      "type": "string"
    },
    "tapId": {
      "type": "string"
    },
    "tapAssignmentId": {
      "type": "string"
    },
    "assignmentId": {
      "type": "string"
    },
    "kegAssetId": {
      "type": "string",
      "description": "Legacy FLOW field for the mounted keg/container identity. Prefer `assetId` for new events."
    },
    "assetId": {
      "type": "string",
      "description": "Canonical physical keg/container UUID mirrored from OS asset identity."
    },
    "assetCode": {
      "type": "string"
    },
    "productId": {
      "type": "string"
    },
    "productCode": {
      "type": "string"
    },
    "skuId": {
      "type": "string"
    },
    "batchId": {
      "type": "string"
    },
    "packageLotId": {
      "type": "string"
    },
    "packageLotCode": {
      "type": "string"
    },
    "labelVersionId": {
      "type": "string"
    },
    "volume": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "uom": {
      "type": "string"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "sourceMode": {
      "type": "string",
      "enum": ["bartender", "self_serve", "test", "maintenance"]
    },
    "sessionId": {
      "type": "string"
    },
    "actorId": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
