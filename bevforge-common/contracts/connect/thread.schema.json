{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/connect/thread.schema.json",
  "title": "BevForge CONNECT Thread",
  "description": "Communication thread linked to operational entities and accounts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "subject",
    "status",
    "channel",
    "participants",
    "messages",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["open", "waiting_external", "resolved", "closed"]
    },
    "channel": {
      "type": "string",
      "enum": ["internal", "email", "sms", "phone", "chat", "other"]
    },
    "accountId": {
      "type": "string"
    },
    "siteId": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actorType", "actorId", "displayName"],
        "properties": {
          "actorType": {
            "type": "string",
            "enum": ["employee", "contact", "system"]
          },
          "actorId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          }
        }
      }
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "authorId", "authorType", "body", "createdAt"],
        "properties": {
          "id": {
            "type": "string"
          },
          "authorId": {
            "type": "string"
          },
          "authorType": {
            "type": "string",
            "enum": ["employee", "contact", "system"]
          },
          "body": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "./event-link.schema.json"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
