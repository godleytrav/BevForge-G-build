{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bevforge.dev/contracts/fulfillment/ops-order.schema.json",
  "title": "BevForge OPS Order",
  "description": "OPS-owned customer order contract consumed by fulfillment integrations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "status",
    "customerId",
    "lines",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "confirmed",
        "allocated",
        "picking",
        "packed",
        "shipped",
        "delivered",
        "canceled"
      ]
    },
    "customerId": {
      "type": "string"
    },
    "siteId": {
      "type": "string"
    },
    "requestedShipAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/orderLine"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "orderLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineId", "skuId", "orderedQty", "uom"],
      "properties": {
        "lineId": {
          "type": "string"
        },
        "skuId": {
          "type": "string"
        },
        "orderedQty": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "uom": {
          "type": "string"
        },
        "allocatedQty": {
          "type": "number",
          "minimum": 0
        },
        "fulfilledQty": {
          "type": "number",
          "minimum": 0
        },
        "batchPreference": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
